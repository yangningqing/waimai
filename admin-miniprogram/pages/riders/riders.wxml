<view class="container">
  <view class="header">
    <text class="header-title">骑手管理</text>
  </view>

  <view class="rider-list">
    <view class="rider-item" wx:for="{{riders}}" wx:key="id" data-id="{{item.id}}">
      <image src="{{item.avatar}}" class="rider-avatar"></image>
      <view class="rider-info">
        <text class="rider-name">{{item.name}}</text>
        <text class="rider-phone">{{item.phone}}</text>
        <text class="rider-status">{{item.status}}</text>
        <text class="rider-stats">今日订单：{{item.todayOrders}} | 总订单：{{item.totalOrders}}</text>
      </view>
      <view class="rider-actions">
        <button class="action-btn" bindtap="viewRiderDetail" data-id="{{item.id}}">详情</button>
        <button class="action-btn" bindtap="editRider" data-id="{{item.id}}">编辑</button>
      </view>
    </view>
  </view>
</view>