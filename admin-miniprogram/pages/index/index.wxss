.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.admin-name {
  font-size: 28rpx;
  color: #666;
}

.stats-section {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  text-align: center;
}

.stat-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.stat-desc {
  font-size: 24rpx;
  color: #999;
}

.order-warning-section,
.rider-section,
.area-section {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.warning-list,
.rider-list,
.area-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.warning-item {
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.warning-id {
  font-size: 28rpx;
  color: #333;
}

.warning-status {
  font-size: 28rpx;
  color: #ff4757;
  font-weight: bold;
}

.warning-time {
  font-size: 24rpx;
  color: #666;
}

.warning-btn {
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 10rpx;
  font-size: 24rpx;
  align-self: flex-start;
  margin-top: 10rpx;
}

.rider-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
}

.rider-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.rider-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.rider-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.rider-status {
  font-size: 24rpx;
  color: #27ae60;
}

.rider-orders {
  font-size: 24rpx;
  color: #666;
}

.rider-btn {
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}

.area-item {
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.area-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.area-orders,
.area-riders {
  font-size: 24rpx;
  color: #666;
}

.area-btn {
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 10rpx;
  font-size: 24rpx;
  align-self: flex-start;
  margin-top: 10rpx;
}