<view class="container">
  <view class="header">
    <text class="header-title">订单管理</text>
  </view>

  <view class="order-tabs">
    <view class="tab-item {{currentTab === index ? 'active' : ''}}" wx:for="{{tabList}}" wx:key="index" bindtap="switchTab" data-index="{{index}}">{{item}}</view>
  </view>

  <view class="order-list">
    <view class="order-item" wx:for="{{orders}}" wx:key="id" data-index="{{index}}">
      <view class="order-header">
        <text class="order-id">订单号：{{item.orderId}}</text>
        <text class="order-status">{{item.status}}</text>
      </view>
      <view class="order-info">
        <text class="info-item">商家：{{item.merchant}}</text>
        <text class="info-item">客户：{{item.customer}}</text>
        <text class="info-item">金额：¥{{item.amount}}</text>
        <text class="info-item">时间：{{item.time}}</text>
      </view>
      <view class="order-actions">
        <button class="action-btn" bindtap="handleOrder" data-index="{{index}}">处理</button>
        <button class="action-btn" bindtap="viewOrderDetail" data-index="{{index}}">详情</button>
      </view>
    </view>
  </view>
</view>