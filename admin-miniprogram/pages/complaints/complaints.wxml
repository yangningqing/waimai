<view class="container">
  <view class="header">
    <text class="header-title">投诉管理</text>
  </view>

  <view class="complaint-list">
    <view class="complaint-item" wx:for="{{complaints}}" wx:key="id" data-id="{{item.id}}">
      <view class="complaint-header">
        <text class="complaint-id">投诉编号：{{item.complaintId}}</text>
        <text class="complaint-status">{{item.status}}</text>
      </view>
      <view class="complaint-info">
        <text class="info-item">客户：{{item.customer}}</text>
        <text class="info-item">订单号：{{item.orderId}}</text>
        <text class="info-item">类型：{{item.type}}</text>
        <text class="info-item">时间：{{item.time}}</text>
      </view>
      <view class="complaint-content">
        <text class="content-title">投诉内容：</text>
        <text class="content-text">{{item.content}}</text>
      </view>
      <view class="complaint-actions">
        <button class="action-btn" bindtap="handleComplaint" data-id="{{item.id}}">处理</button>
        <button class="action-btn" bindtap="viewComplaintDetail" data-id="{{item.id}}">详情</button>
      </view>
    </view>
  </view>
</view>