.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 28rpx;
}

.area-list {
  padding: 0 20rpx;
}

.area-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.area-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.area-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.area-status {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
  background-color: #e8f5e8;
  color: #27ae60;
}

.area-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.info-item {
  font-size: 24rpx;
  color: #666;
}

.area-actions {
  display: flex;
  gap: 15rpx;
  justify-content: flex-end;
}

.action-btn {
  border: 1rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  background-color: #fff;
  color: #333;
}

.fence-btn {
  color: #ff4757;
  border-color: #ff4757;
}

.delete-btn {
  color: #ff4757;
  border-color: #ff4757;
}

.fence-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.modal-content {
  background-color: #fff;
  border-radius: 20rpx;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.modal-header text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
}

.modal-body {
  padding: 20rpx;
}

.map-container {
  margin-bottom: 20rpx;
}

.map-image {
  width: 100%;
  height: 300rpx;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
}

.fence-controls {
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
}

.control-btn {
  flex: 1;
  background-color: #f0f0f0;
  border: none;
  border-radius: 10rpx;
  padding: 15rpx;
  font-size: 24rpx;
}

.fence-info {
  margin-bottom: 20rpx;
}

.info-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 15rpx;
  font-size: 28rpx;
  width: 100%;
}

.textarea {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 15rpx;
  font-size: 28rpx;
  min-height: 150rpx;
  width: 100%;
}