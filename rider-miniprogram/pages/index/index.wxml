<view class="container">
  <!-- 顶部状态栏 -->
  <view class="top-bar">
    <view class="online-status" bindtap="toggleOnline">
      <text class="status-text">{{isOnline ? '在线' : '离线'}}</text>
      <text class="status-arrow">▼</text>
    </view>
    <view class="logout-btn" bindtap="logout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>

  <!-- 标签页 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">待抢单</view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">配送中</view>
    <view class="tab-item {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">已完成</view>
  </view>

  <!-- 待抢单列表 -->
  <view class="order-list" wx:if="{{currentTab === 0}}">
    <view class="order-item priority" wx:for="{{pendingOrders}}" wx:key="id" data-index="{{index}}">
      <view class="order-header" bindtap="viewOrderDetail" data-index="{{index}}">
        <text class="delivery-time">预计 {{item.deliveryTime}} 送达</text>
        <view class="order-tags">
          <text class="tag shop-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
      </view>
      <view class="order-content">
        <view class="order-info">
          <text class="distance">{{item.distance}}</text>
          <text class="wait-time" wx:if="{{item.waitTime}}">{{item.waitTime}}</text>
        </view>
        <view class="order-info">
          <text class="info-value">商家：{{item.shopName}}</text>
        </view>
        <view class="order-info">
          <text class="info-value">客户：{{item.customerName}}</text>
        </view>
      </view>
      <view class="order-actions">
        <button class="action-btn accept-btn" bindtap="acceptOrder" data-index="{{index}}">立即抢单</button>
      </view>
    </view>
  </view>

  <!-- 配送中列表 -->
  <view class="order-list" wx:if="{{currentTab === 1}}">
    <view class="order-item" wx:for="{{deliveringOrders}}" wx:key="id" data-index="{{index}}">
      <view class="order-header" bindtap="viewOrderDetail" data-index="{{index}}">
        <text class="delivery-time">预计 {{item.deliveryTime}} 送达</text>
        <text class="order-status">{{item.status}}</text>
      </view>
      <view class="order-content">
        <view class="order-info">
          <text class="distance">{{item.distance}}</text>
        </view>
        <view class="order-info">
          <text class="info-value">商家：{{item.shopName}}</text>
        </view>
        <view class="order-info">
          <text class="info-value">客户：{{item.customerName}}</text>
        </view>
      </view>
      <view class="order-actions">
        <button class="action-btn" bindtap="navigateToShop" data-index="{{index}}">导航到店</button>
        <button class="action-btn" bindtap="navigateToCustomer" data-index="{{index}}">导航送达</button>
        <button class="action-btn" bindtap="callCustomer" data-index="{{index}}">联系客户</button>
        <button class="action-btn accept-btn" bindtap="completeDelivery" data-index="{{index}}">完成配送</button>
        <button class="action-btn" bindtap="reportException" data-index="{{index}}">异常上报</button>
      </view>
    </view>
  </view>

  <!-- 已完成列表 -->
  <view class="order-list" wx:if="{{currentTab === 2}}">
    <view class="order-item" wx:for="{{completedOrders}}" wx:key="id" data-index="{{index}}">
      <view class="order-header" bindtap="viewOrderDetail" data-index="{{index}}">
        <text class="delivery-time">{{item.deliveryTime}}</text>
        <text class="order-status">{{item.status}}</text>
      </view>
      <view class="order-content">
        <view class="order-info">
          <text class="distance">{{item.distance}}</text>
        </view>
        <view class="order-info">
          <text class="info-value">商家：{{item.shopName}}</text>
        </view>
        <view class="order-info">
          <text class="info-value">客户：{{item.customerName}}</text>
        </view>
        <view class="order-info" wx:if="{{item.amount}}">
          <text class="info-value">收入：¥{{item.amount}}</text>
        </view>
      </view>
    </view>
  </view>
</view>