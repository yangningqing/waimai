.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 顶部状态栏 */
.top-bar {
  background-color: #4a90e2;
  color: #fff;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.online-status {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.status-arrow {
  margin-left: 10rpx;
  font-size: 20rpx;
}

.logout-btn {
  font-size: 28rpx;
}

.logout-text {
  color: #fff;
}

/* 标签页 */
.tab-bar {
  background-color: #fff;
  display: flex;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 3rpx solid transparent;
}

.tab-item.active {
  color: #4a90e2;
  border-bottom-color: #4a90e2;
  font-weight: bold;
}

/* 订单列表 */
.order-list {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.order-item.priority {
  border-left: 10rpx solid #ff4757;
}

.order-header {
  margin-bottom: 15rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.delivery-time {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.order-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 20rpx;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
  color: #fff;
}

.shop-tag {
  background-color: #ff9800;
}

.help-tag {
  background-color: #4caf50;
}

.douyin-tag {
  background-color: #ff6b6b;
}

.urgent-tag {
  background-color: #f44336;
}

.order-content {
  margin-bottom: 15rpx;
}

.order-info {
  margin-bottom: 10rpx;
}

.distance {
  font-size: 28rpx;
  color: #ff4757;
  font-weight: bold;
  margin-right: 20rpx;
}

.wait-time {
  font-size: 24rpx;
  color: #f44336;
}

.info-value {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.order-actions {
  padding-top: 15rpx;
  border-top: 1rpx solid #e0e0e0;
}

.action-btn {
  width: 100%;
  border: none;
  border-radius: 25rpx;
  padding: 15rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.accept-btn {
  background-color: #4a90e2;
  color: #fff;
}

/* 底部提示 */
.bottom-tip {
  padding: 20rpx;
  background-color: #fff;
  margin-top: 20rpx;
  border-top: 1rpx solid #e0e0e0;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  text-align: center;
}
