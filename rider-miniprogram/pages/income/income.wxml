<view class="container">
  <view class="header">
    <text class="header-title">收入统计</text>
  </view>

  <view class="income-summary">
    <view class="summary-item">
      <text class="summary-label">今日收入</text>
      <text class="summary-value">¥{{todayIncome}}</text>
    </view>
    <view class="summary-item">
      <text class="summary-label">今日单量</text>
      <text class="summary-value">{{todayOrders}}</text>
    </view>
  </view>

  <view class="income-list">
    <view class="list-header">
      <text class="list-title">今日收入明细</text>
    </view>

    <view class="income-item" wx:for="{{incomeList}}" wx:key="orderId">
      <view class="income-info">
        <text class="income-order">订单：{{item.orderId}}</text>
        <text class="income-time">{{item.time}}</text>
      </view>
      <text class="income-amount">+{{item.amount}}</text>
    </view>
  </view>
</view>