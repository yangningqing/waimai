<view class="container">
  <view class="header">
    <text class="header-title">订单列表</text>
  </view>

  <view class="order-list">
    <view class="order-item" wx:for="{{orders}}" wx:key="id" data-index="{{index}}">
      <view class="order-header">
        <text class="order-id">订单号：{{item.id}}</text>
        <text class="order-status">{{item.status}}</text>
      </view>
      <view class="order-content">
        <text class="shop-name">{{item.shopName}}</text>
        <text class="customer-name">{{item.customerName}}</text>
        <text class="address">{{item.customerAddress}}</text>
        <view class="order-time">
          <text class="time-label">倒计时：</text>
          <text class="time-value">{{item.remainingTime}}</text>
        </view>
      </view>
      <view class="order-actions" wx:if="{{item.status === '待取餐'}}">
        <button class="action-btn" bindtap="navigateToShop" data-index="{{index}}">导航到店</button>
        <button class="action-btn primary" bindtap="confirmPickup" data-index="{{index}}">确认取餐</button>
      </view>
      <view class="order-actions" wx:if="{{item.status === '配送中'}}">
        <button class="action-btn" bindtap="navigateToCustomer" data-index="{{index}}">导航送达</button>
        <button class="action-btn" bindtap="callCustomer" data-index="{{index}}">联系客户</button>
        <button class="action-btn primary" bindtap="completeDelivery" data-index="{{index}}">完成配送</button>
        <button class="action-btn exception" bindtap="reportException" data-index="{{index}}">异常上报</button>
      </view>
    </view>
  </view>
</view>