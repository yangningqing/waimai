.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.order-list {
  padding: 0 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.order-id {
  font-size: 28rpx;
  color: #666;
}

.order-status {
  font-size: 28rpx;
  color: #ff4757;
  font-weight: bold;
}

.order-content {
  margin-bottom: 15rpx;
}

.shop-name,
.customer-name,
.address {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.order-time {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.time-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 10rpx;
}

.time-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4757;
}

.order-actions {
  display: flex;
  gap: 15rpx;
  justify-content: flex-end;
}

.action-btn {
  border: 1rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  background-color: #fff;
  color: #333;
}

.action-btn.primary {
  background-color: #ff4757;
  color: #fff;
  border: none;
}
