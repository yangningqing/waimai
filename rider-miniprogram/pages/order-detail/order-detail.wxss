.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.order-detail {
  padding: 20rpx;
}

.order-info-section,
.merchant-section,
.customer-section,
.goods-section {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.order-info {
  display: flex;
  margin-bottom: 15rpx;
}

.info-label {
  width: 150rpx;
  font-size: 28rpx;
  color: #666;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.info-value.countdown {
  color: #ff4757;
  font-weight: bold;
}

.merchant-info,
.customer-info {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.merchant-name,
.customer-name {
  font-size: 32rpx;
  font-weight: bold;
}

.merchant-address,
.customer-address {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.customer-phone {
  font-size: 28rpx;
  color: #666;
}

.location-image {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.image-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 15rpx;
}

.image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
}

.nav-btn {
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 15rpx;
  font-size: 28rpx;
  margin-top: 10rpx;
  width: 100%;
}

.goods-list {
  margin-bottom: 20rpx;
}

.goods-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.goods-quantity {
  font-size: 28rpx;
  color: #666;
  margin: 0 20rpx;
}

.goods-price {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.total-section,
.income-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #e0e0e0;
}

.total-label,
.income-label {
  font-size: 28rpx;
  color: #666;
}

.total-value,
.income-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.income-value {
  color: #27ae60;
}

.action-section {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  border: 1rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 15rpx;
  font-size: 28rpx;
}

.report-btn {
  background-color: #fff;
  color: #ff4757;
  border-color: #ff4757;
}

.complete-btn {
  background-color: #27ae60;
  color: #fff;
  border: none;
}