/* 全局样式 */

page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding-bottom: 100rpx;
  box-sizing: border-box;
}

.header {
  height: 88rpx;
  line-height: 88rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  padding: 0 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 20rpx 0;
  padding: 0 20rpx;
}

.btn {
  background-color: #07c160;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  padding: 15rpx 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.btn-danger {
  background-color: #ff4d4f;
  color: #fff;
}

.btn-outline {
  background-color: #fff;
  color: #07c160;
  border: 1rpx solid #07c160;
}

.card {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  box-sizing: border-box;
}

.list-item:last-child {
  border-bottom: none;
}

.text-primary {
  color: #07c160;
}

.text-danger {
  color: #ff4d4f;
}

.text-muted {
  color: #999;
}

.mt-10 {
  margin-top: 10rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.p-20 {
  padding: 20rpx;
}