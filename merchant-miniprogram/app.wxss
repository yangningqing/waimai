/* 全局样式 */
page, view, text, image, button, input, textarea {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

button {
  border: none;
  outline: none;
}

input, textarea {
  border: none;
  outline: none;
}

image {
  width: 100%;
  height: 100%;
}
