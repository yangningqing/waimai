<view class="container">
  <view class="header">
    <text class="header-title">订单管理</text>
  </view>

  <view class="status-tabs">
    <view class="tab-item {{currentTab === index ? 'active' : ''}}" wx:for="{{tabList}}" wx:key="index" bindtap="switchTab" data-index="{{index}}">{{item}}</view>
  </view>

  <view class="order-list">
    <view class="order-item" wx:for="{{orderList}}" wx:key="id" data-index="{{index}}">
      <view class="order-header">
        <text class="order-id">订单号：{{item.id}}</text>
        <text class="order-status">{{item.status}}</text>
      </view>
      <view class="order-content">
        <text class="customer-name">{{item.customerName}}</text>
        <text class="goods-info">{{item.goodsInfo}}</text>
        <text class="order-time">下单时间：{{item.orderTime}}</text>
        <text class="order-price">¥{{item.price}}</text>
      </view>
      <view class="order-actions">
        <button class="action-btn accept-btn" bindtap="acceptOrder" data-index="{{index}}" wx:if="{{item.status === '待接单'}}">接单</button>
        <button class="action-btn" bindtap="rejectOrder" data-index="{{index}}" wx:if="{{item.status === '待接单'}}">拒单</button>
        <button class="action-btn" bindtap="viewDetail" data-index="{{index}}" wx:if="{{item.status === '配送中'}}">查看详情</button>
        <button class="action-btn accept-btn" bindtap="completeOrder" data-index="{{index}}" wx:if="{{item.status === '配送中'}}">完成订单</button>
      </view>
    </view>
  </view>
</view>