.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.status-tabs {
  background-color: #fff;
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 3rpx solid transparent;
}

.tab-item.active {
  color: #ff4757;
  border-bottom-color: #ff4757;
  font-weight: bold;
}

.order-list {
  padding: 0 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.order-id {
  font-size: 28rpx;
  color: #666;
}

.order-status {
  font-size: 28rpx;
  color: #ff4757;
  font-weight: bold;
}

.order-content {
  margin-bottom: 15rpx;
}

.customer-name,
.goods-info,
.order-time {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.order-price {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4757;
  margin-top: 10rpx;
}

.order-actions {
  display: flex;
  gap: 15rpx;
  justify-content: flex-end;
}

.action-btn {
  border: 1rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  background-color: #fff;
  color: #333;
}

.accept-btn {
  background-color: #ff4757;
  color: #fff;
  border: none;
}
