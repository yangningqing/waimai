.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 搜索栏 */
.search-bar {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.search-input {
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 15rpx 20rpx;
  font-size: 28rpx;
  color: #333;
}

/* 状态筛选 */
.status-filter {
  display: flex;
  background-color: #fff;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.status-item {
  padding: 15rpx 20rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
  border-bottom: 2rpx solid transparent;
}

.status-item.active {
  color: #07c160;
  border-bottom: 2rpx solid #07c160;
  font-weight: 600;
}

/* 订单列表 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  padding: 0 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.order-id {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.order-status {
  font-size: 26rpx;
  font-weight: 600;
}

.order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.order-user {
  font-size: 26rpx;
  color: #333;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-address {
  margin-bottom: 15rpx;
}

.address-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.order-items {
  margin-bottom: 15rpx;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.order-item-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.order-item-detail:last-child {
  margin-bottom: 0;
}

.item-name {
  font-size: 24rpx;
  color: #333;
  flex: 1;
}

.item-price {
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #eee;
}

.order-amount {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.order-action {
  font-size: 24rpx;
  color: #07c160;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  background-color: #f9f9f9;
  margin: 20rpx;
  border-radius: 10rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}
