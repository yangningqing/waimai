.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 15rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  margin-right: 15rpx;
}

.add-btn {
  background-color: #07c160;
  color: #fff;
  border: none;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  font-size: 40rpx;
  line-height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 分类导航 */
.category-nav {
  display: flex;
  background-color: #fff;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.category-item {
  padding: 15rpx 20rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
  border-bottom: 2rpx solid transparent;
}

.category-item.active {
  color: #07c160;
  border-bottom: 2rpx solid #07c160;
  font-weight: 600;
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  padding: 0 20rpx;
}

.goods-item {
  display: flex;
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  align-items: center;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4757;
  margin-bottom: 5rpx;
}

.goods-stock {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.goods-sales {
  font-size: 24rpx;
  color: #999;
}

.goods-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: 1rpx solid #ddd;
  background-color: #fff;
}

.edit-btn {
  color: #07c160;
  border-color: #07c160;
}

.delete-btn {
  color: #ff4d4f;
  border-color: #ff4d4f;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  background-color: #f9f9f9;
  margin: 20rpx;
  border-radius: 10rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}
