<view class="container">
  <view class="header">
    <text class="header-title">商品管理</text>
  </view>

  <view class="category-list">
    <view class="category-item {{currentCategory === index ? 'active' : ''}}" wx:for="{{categoryList}}" wx:key="index" bindtap="switchCategory" data-index="{{index}}">{{item}}</view>
  </view>

  <view class="goods-list">
    <view class="goods-item" wx:for="{{goodsList}}" wx:key="id" data-index="{{index}}">
      <view class="goods-info">
        <view class="goods-icon">{{item.icon}}</view>
        <view class="goods-detail">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">¥{{item.price}}</text>
          <text class="goods-status">{{item.status}}</text>
        </view>
      </view>
      <view class="goods-actions">
        <button class="edit-btn" bindtap="editGoods" data-index="{{index}}">编辑</button>
        <button class="off-btn" bindtap="offGoods" data-index="{{index}}">{{item.status === '上架中' ? '下架' : '上架'}}</button>
      </view>
    </view>
  </view>

  <view class="add-btn">
    <button bindtap="addGoods">添加商品</button>
  </view>
</view>