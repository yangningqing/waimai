<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索商品" bindinput="handleSearchInput" value="{{searchText}}" />
    <button class="add-btn" bindtap="handleAddGoods">+</button>
  </view>

  <!-- 分类导航 -->
  <view class="category-nav">
    <view wx:for="{{categories}}" wx:key="*this" class="category-item {{currentCategory === item ? 'active' : ''}}" data-category="{{item}}" bindtap="handleCategoryChange">
      {{item}}
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="goods-list">
    <view wx:for="{{goodsList}}" wx:key="id" class="goods-item">
      <image src="{{item.image}}" class="goods-image" mode="aspectFill"></image>
      <view class="goods-info">
        <text class="goods-name">{{item.name}}</text>
        <text class="goods-price">¥{{item.price}}</text>
        <text class="goods-sales">已售: {{item.sales}}</text>
      </view>
      <view class="goods-actions">
        <button class="action-btn edit-btn" data-id="{{item.id}}" data-action="edit" bindtap="handleGoodsAction">编辑</button>
        <button class="action-btn delete-btn" data-id="{{item.id}}" data-action="delete" bindtap="handleGoodsAction">删除</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{goodsList.length === 0}}" class="empty-state">
    <text class="empty-text">暂无商品</text>
  </view>
</view>