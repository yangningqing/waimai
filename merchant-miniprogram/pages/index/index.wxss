.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 统计卡片 */
.stats-container {
  display: flex;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  border-right: 1rpx solid #eee;
}

.stat-card:last-child {
  border-right: none;
}

.stat-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.action-label {
  font-size: 24rpx;
  color: #666;
}

/* 通用 section 样式 */
.section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.more {
  font-size: 24rpx;
  color: #999;
}

/* 订单列表 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.order-item {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  border-left: 4rpx solid #07c160;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.order-id {
  font-size: 26rpx;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  font-weight: 600;
}

.order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.order-time {
  font-size: 24rpx;
  color: #666;
}

.order-amount {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.order-action {
  text-align: right;
}

.action-text {
  font-size: 24rpx;
  color: #07c160;
  font-weight: 600;
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.goods-item {
  width: calc(50% - 10rpx);
  background-color: #f9f9f9;
  border-radius: 10rpx;
  overflow: hidden;
}

.goods-image {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
}

.goods-info {
  padding: 15rpx;
}

.goods-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 5rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4757;
  margin-bottom: 5rpx;
}

.goods-sales {
  font-size: 22rpx;
  color: #999;
}
