<view class="container">
  <view class="login-form">
    <view class="logo">
      <view class="logo-icon">🏪</view>
      <view class="logo-text">商家登录</view>
    </view>
    
    <view class="form-item">
      <input class="input" placeholder="请输入账号" bindinput="handleUsernameInput" value="{{username}}" />
    </view>
    
    <view class="form-item">
      <input class="input" placeholder="请输入密码" password bindinput="handlePasswordInput" value="{{password}}" />
    </view>
    
    <button class="login-btn" bindtap="handleLogin">登录</button>
    
    <view class="register-link">
      <text>还没有账号？</text>
      <text class="register-text" bindtap="navigateToRegister">立即注册</text>
    </view>
  </view>
</view>