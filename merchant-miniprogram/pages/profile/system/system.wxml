<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">系统设置</text>
  </view>

  <!-- 系统信息 -->
  <view class="info-section">
    <view class="info-item">
      <text class="info-label">版本号</text>
      <text class="info-value">{{systemInfo.version}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">更新时间</text>
      <text class="info-value">{{systemInfo.updateTime}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">设备信息</text>
      <text class="info-value">{{systemInfo.deviceInfo}}</text>
    </view>
  </view>

  <!-- 设置选项 -->
  <view class="setting-section">
    <view class="setting-item" bindtap="handleClearCache">
      <text class="setting-label">清除缓存</text>
      <view class="setting-arrow">→</view>
    </view>
    <view class="setting-item" bindtap="handleCheckUpdate">
      <text class="setting-label">检查更新</text>
      <view class="setting-arrow">→</view>
    </view>
    <view class="setting-item" bindtap="handleAbout">
      <text class="setting-label">关于</text>
      <view class="setting-arrow">→</view>
    </view>
  </view>

  <!-- 返回按钮 -->
  <view class="actions">
    <button class="back-btn" bindtap="handleBack">返回</button>
  </view>
</view>
