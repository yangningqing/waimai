.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.balance-section {
  margin-bottom: 20rpx;
}

.balance-card {
  background-color: #4caf50;
  padding: 30rpx;
  border-radius: 10rpx;
  color: #fff;
  text-align: center;
}

.balance-label {
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.balance-amount {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.withdraw-btn {
  background-color: #fff;
  color: #4caf50;
  border: none;
  border-radius: 5rpx;
  padding: 15rpx 30rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.section {
  background-color: #fff;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.section-header {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.withdrawal-list,
.transaction-list {
  padding: 0 20rpx;
}

.withdrawal-item,
.transaction-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.withdrawal-item:last-child,
.transaction-item:last-child {
  border-bottom: none;
}

.withdrawal-info,
.transaction-info {
  flex: 1;
}

.withdrawal-amount,
.transaction-amount {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.withdrawal-time,
.transaction-time,
.transaction-order {
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}

.withdrawal-status {
  font-size: 28rpx;
  font-weight: bold;
}

.transaction-type {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  display: block;
}

.empty-state {
  background-color: #fff;
  padding: 100rpx 20rpx;
  border-radius: 10rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.actions {
  margin-top: 40rpx;
  text-align: center;
}

.back-btn {
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  font-size: 28rpx;
  background-color: #fff;
  color: #666;
  width: 200rpx;
}
