<view class="container">
  <view class="profile-header">
    <view class="avatar">商</view>
    <view class="profile-info">
      <text class="name">{{name}}</text>
      <text class="phone">{{phone}}</text>
    </view>
  </view>

  <view class="profile-stats">
    <view class="stat-item">
      <text class="stat-value">{{todayOrders}}</text>
      <text class="stat-label">今日订单</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{rating}}</text>
      <text class="stat-label">评分</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{goodRate}}</text>
      <text class="stat-label">好评率</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="navigateToShopManagement">
      <text class="menu-label">店铺管理</text>
      <text class="menu-arrow">&gt;</text>
    </view>
    <view class="menu-item" bindtap="navigateToFinance">
      <text class="menu-label">财务管理</text>
      <text class="menu-arrow">&gt;</text>
    </view>
    <view class="menu-item" bindtap="navigateToOrders">
      <text class="menu-label">订单记录</text>
      <text class="menu-arrow">&gt;</text>
    </view>
    <view class="menu-item" bindtap="navigateToFeedback">
      <text class="menu-label">意见反馈</text>
      <text class="menu-arrow">&gt;</text>
    </view>
    <view class="menu-item" bindtap="navigateToSettings">
      <text class="menu-label">设置</text>
      <text class="menu-arrow">&gt;</text>
    </view>
  </view>

  <view class="logout-btn">
    <button bindtap="logout">退出登录</button>
  </view>
</view>