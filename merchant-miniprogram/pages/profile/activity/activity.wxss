.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.activity-list {
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.activity-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.activity-status {
  font-size: 24rpx;
  font-weight: bold;
  margin-left: 20rpx;
}

.activity-content {
  margin-bottom: 15rpx;
}

.activity-description {
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
}

.activity-footer {
  display: flex;
  justify-content: flex-end;
}

.activity-date {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  background-color: #fff;
  padding: 100rpx 20rpx;
  border-radius: 10rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.create-section {
  margin-bottom: 20rpx;
  text-align: center;
}

.create-btn {
  background-color: #4caf50;
  color: #fff;
  border: none;
  border-radius: 5rpx;
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  width: 100%;
}

.actions {
  margin-top: 40rpx;
  text-align: center;
}

.back-btn {
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  font-size: 28rpx;
  background-color: #fff;
  color: #666;
  width: 200rpx;
}
