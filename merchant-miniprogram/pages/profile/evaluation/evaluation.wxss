.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.evaluation-list {
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.evaluation-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.evaluation-item:last-child {
  border-bottom: none;
}

.evaluation-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  display: block;
}

.evaluation-time {
  font-size: 24rpx;
  color: #999;
}

.rating {
  display: flex;
  align-items: center;
}

.star {
  font-size: 28rpx;
  margin-left: 5rpx;
}

.evaluation-content {
  margin-bottom: 15rpx;
}

.content-text {
  font-size: 26rpx;
  color: #333;
  line-height: 40rpx;
}

.evaluation-footer {
  display: flex;
  justify-content: flex-end;
}

.goods-name {
  font-size: 24rpx;
  color: #666;
}

.empty-state {
  background-color: #fff;
  padding: 100rpx 20rpx;
  border-radius: 10rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.actions {
  margin-top: 40rpx;
  text-align: center;
}

.back-btn {
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  font-size: 28rpx;
  background-color: #fff;
  color: #666;
  width: 200rpx;
}
