.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.form {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  font-size: 28rpx;
}

.input--photo {
  margin-top: 16rpx;
}

.photo-block {
  margin-bottom: 36rpx;
}

.photo-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-top: 12rpx;
}

.shop-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #eee;
  flex-shrink: 0;
}

.shop-preview--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  border: 1rpx dashed #ccc;
}

.photo-actions {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.photo-btn {
  margin: 0;
  font-size: 26rpx;
}

.photo-btn--danger {
  color: #c62828;
}

.hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  line-height: 1.5;
}

.actions {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
}

.cancel-btn {
  flex: 1;
  margin-right: 20rpx;
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  font-size: 28rpx;
  background-color: #fff;
  color: #666;
}

.save-btn {
  flex: 1;
  margin-left: 20rpx;
  padding: 20rpx;
  border: none;
  border-radius: 5rpx;
  font-size: 28rpx;
  background-color: #4caf50;
  color: #fff;
}
