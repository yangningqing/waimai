<view class="container">
  <!-- 今日收入 -->
  <view class="today-income">
    <view class="income-card">
      <view class="income-title">今日收入</view>
      <view class="income-amount">¥{{todayIncome}}</view>
      <view class="income-orders">今日订单: {{todayOrders}}</view>
    </view>
  </view>

  <!-- 历史收入 -->
  <view class="history-income">
    <view class="section-header">
      <text class="section-title">历史收入</text>
      <button class="refresh-btn" bindtap="handleRefresh">刷新</button>
    </view>
    <view class="income-list">
      <view wx:for="{{incomeList}}" wx:key="date" class="income-item">
        <view class="income-date">{{date}}</view>
        <view class="income-info">
          <text class="income-value">¥{{income}}</text>
          <text class="income-orders-count">{{orders}} 单</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{incomeList.length === 0}}" class="empty-state">
    <text class="empty-text">暂无收入数据</text>
  </view>
</view>