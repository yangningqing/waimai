.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 今日收入 */
.today-income {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.income-card {
  background-color: #07c160;
  color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.3);
}

.income-title {
  font-size: 28rpx;
  margin-bottom: 15rpx;
  opacity: 0.9;
}

.income-amount {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.income-orders {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 历史收入 */
.history-income {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.refresh-btn {
  background-color: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}

/* 收入列表 */
.income-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.income-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  border-left: 4rpx solid #07c160;
}

.income-date {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

.income-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.income-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.income-orders-count {
  font-size: 24rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  background-color: #f9f9f9;
  margin: 20rpx;
  border-radius: 10rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}
