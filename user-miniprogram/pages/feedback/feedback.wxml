<view class="container">
  <view class="header">
    <text class="header-title">意见反馈</text>
  </view>

  <view class="feedback-form">
    <view class="form-item">
      <text class="form-label">反馈类型</text>
      <view class="form-options">
        <view class="option-item {{feedbackType === '建议' ? 'active' : ''}}" bindtap="selectType" data-type="建议">
          <text class="option-text">建议</text>
        </view>
        <view class="option-item {{feedbackType === '投诉' ? 'active' : ''}}" bindtap="selectType" data-type="投诉">
          <text class="option-text">投诉</text>
        </view>
        <view class="option-item {{feedbackType === '其他' ? 'active' : ''}}" bindtap="selectType" data-type="其他">
          <text class="option-text">其他</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">反馈内容</text>
      <textarea class="form-textarea" placeholder="请输入您的反馈内容" value="{{feedbackContent}}" bindinput="inputContent"></textarea>
    </view>

    <view class="form-item">
      <text class="form-label">上传图片</text>
      <view class="image-uploader">
        <view class="upload-item" wx:for="{{feedbackImages}}" wx:key="index">
          <image src="{{item}}" class="uploaded-image"></image>
          <text class="delete-image" bindtap="deleteImage" data-index="{{index}}">×</text>
        </view>
        <view class="upload-item" wx:if="{{feedbackImages.length < 9}}" bindtap="uploadImage">
          <text class="upload-icon">+</text>
          <text class="upload-text">点击上传</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">联系方式</text>
      <input class="form-input" placeholder="请输入您的联系方式" value="{{contactInfo}}" bindinput="inputContact"></input>
    </view>

    <button class="submit-btn" bindtap="submitFeedback">提交反馈</button>
  </view>
</view>