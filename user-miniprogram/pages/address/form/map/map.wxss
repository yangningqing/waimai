.container { min-height: 100vh; background: #f6f6f6; }
.header {
  height: 88rpx; display: flex; align-items: center; justify-content: space-between;
  padding: 0 24rpx; background: #fff; border-bottom: 1rpx solid #eee;
}
.nav-btn { width: 120rpx; font-size: 28rpx; color: #333; }
.nav-btn.right { text-align: right; }
.title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 600; }
.search-bar {
  background: #fff; padding: 14rpx 20rpx; display: flex; align-items: center; gap: 14rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.city { font-size: 28rpx; color: #333; }
.search-input { flex: 1; background: #f5f5f5; border-radius: 30rpx; padding: 10rpx 20rpx; font-size: 26rpx; }
.map { width: 100%; height: 520rpx; position: relative; }
.bubble {
  position: absolute; left: 50%; top: 42%;
  transform: translate(-50%, -100%);
  background: #fff; border-radius: 12rpx; padding: 10rpx 16rpx; font-size: 24rpx; color: #333;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.15);
}
.candidate-panel {
  margin-top: -20rpx; background: #fff; border-top-left-radius: 20rpx; border-top-right-radius: 20rpx;
  padding: 12rpx 20rpx 20rpx;
}
.candidate-item {
  padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; display: flex; justify-content: space-between; align-items: center;
}
.name { display: block; font-size: 32rpx; color: #222; margin-bottom: 6rpx; }
.detail { display: block; font-size: 24rpx; color: #999; }
.radio { font-size: 34rpx; color: #bbb; }
.candidate-item.active .radio { color: #ffcc00; }
.confirm-btn { margin-top: 14rpx; background: #ffe84a; color: #333; border-radius: 12rpx; font-size: 32rpx; }
