<view class="container">
  <view class="header">
    <text class="back-btn" bindtap="onBack">‹</text>
    <text class="header-title">我的收货地址</text>
    <text class="header-action" bindtap="navigateToAddAddress">新增地址</text>
  </view>

  <view class="address-list">
    <view class="address-item" wx:for="{{addresses}}" wx:key="id" data-index="{{index}}">
      <view class="address-info" bindtap="selectAddress" data-index="{{index}}">
        <view class="address-main-line">
          <text class="address-full">{{item.address}}</text>
          <text class="edit-btn" bindtap="editAddress" data-index="{{index}}">编辑</text>
        </view>
        <view class="address-sub-line">
          <text class="address-name">{{item.name}}</text>
          <text class="address-gender">先生</text>
          <text class="address-phone">{{item.phone}}</text>
          <text class="default-tag" wx:if="{{item.isDefault}}">默认</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-address" wx:if="{{addresses.length === 0}}">
    <text class="empty-text">暂无地址</text>
  </view>
</view>