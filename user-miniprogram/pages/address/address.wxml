<view class="container">
  <view class="header">
    <text class="header-title">地址管理</text>
  </view>

  <view class="address-list">
    <view class="address-item" wx:for="{{addresses}}" wx:key="id" data-index="{{index}}">
      <view class="address-info" bindtap="selectAddress" data-index="{{index}}">
        <view class="address-header">
          <text class="address-name">{{item.name}}</text>
          <text class="address-phone">{{item.phone}}</text>
          <text class="address-tag" wx:if="{{item.isDefault}}">默认</text>
          <text class="address-tag" wx:else bindtap="setDefault" data-index="{{index}}">设为默认</text>
        </view>
        <view class="address-detail">
          <text class="address-full">{{item.address}}</text>
        </view>
        <image src="{{item.image}}" class="address-image" wx:if="{{item.image}}"></image>
      </view>
      <view class="address-actions">
        <button class="action-btn" bindtap="editAddress" data-index="{{index}}">编辑</button>
        <button class="action-btn" bindtap="deleteAddress" data-index="{{index}}">删除</button>
      </view>
    </view>
  </view>

  <button class="add-address-btn" bindtap="addAddress">添加新地址</button>

  <view class="empty-address" wx:if="{{addresses.length === 0}}">
    <text class="empty-text">暂无地址</text>
  </view>
</view>