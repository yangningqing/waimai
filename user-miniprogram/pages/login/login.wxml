<view class="container">
  <view class="card">
    <text class="title">登录账号</text>
    <input
      class="input"
      placeholder="请输入账号"
      value="{{username}}"
      bindinput="onUsernameInput"
    />
    <input
      class="input"
      password
      placeholder="请输入密码"
      value="{{password}}"
      bindinput="onPasswordInput"
    />
    <button class="login-btn" bindtap="handleLogin">登录</button>
    <view class="footer">
      <text class="register-link" bindtap="navigateToRegister">注册</text>
    </view>
  </view>
</view>
