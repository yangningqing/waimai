.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.tab-section {
  background-color: #fff;
  display: flex;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item.active {
  color: #ff4757;
  border-bottom: 2rpx solid #ff4757;
}

.order-list {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.order-shop {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  color: #ff4757;
}

.order-content {
  margin-bottom: 20rpx;
}

.order-goods {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 15rpx;
}

.goods-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
}

.goods-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.goods-quantity {
  font-size: 24rpx;
  color: #999;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 10rpx;
  border-top: 1rpx solid #e0e0e0;
}

.order-total {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.order-actions {
  display: flex;
  gap: 15rpx;
}

.action-btn {
  border: 1rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  background-color: #fff;
  color: #333;
}

.action-btn.primary {
  background-color: #ff4757;
  color: #fff;
  border: none;
}

.empty-order {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}