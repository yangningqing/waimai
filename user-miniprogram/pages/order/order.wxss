.container {
  background-color: #f5f5f6;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.topbar {
  padding: 16rpx 20rpx 10rpx;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-wrap {
  height: 64rpx;
  background-color: #f4f4f5;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.search-icon {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.clear-btn {
  font-size: 22rpx;
  color: #999;
}

.top-actions {
  margin-top: 8rpx;
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.top-action {
  font-size: 22rpx;
  color: #666;
}

.tab-section {
  display: flex;
  background-color: #fff;
  padding: 12rpx 8rpx 6rpx;
  margin-bottom: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 0 14rpx;
  padding-bottom: 10rpx;
  border-bottom: 4rpx solid transparent;
}

.tab-label {
  font-size: 32rpx;
  color: #666;
}

.tab-item.active {
  border-bottom-color: #222;
}

.tab-item.active .tab-label {
  color: #111;
  font-weight: 600;
}

.loading-wrap {
  margin-top: 200rpx;
  text-align: center;
}

.loading-text {
  font-size: 26rpx;
  color: #86909c;
}

.order-list {
  padding: 0 12rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 18rpx;
  padding: 20rpx 18rpx;
  margin-bottom: 12rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.shop-wrap {
  max-width: 76%;
}

.order-shop {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-status {
  font-size: 34rpx;
  color: #666;
  padding: 0;
}

.order-status.pending-pay {
  color: #ff6a00;
}

.order-status.pending-delivery {
  color: #1e6fff;
}

.order-status.pending-comment {
  color: #ff6a00;
}

.order-status.after-sale {
  color: #ff3b30;
}

.order-status.completed {
  color: #666;
}

.order-status.default {
  color: #666;
}

.order-content {
  margin-bottom: 12rpx;
}

.order-goods {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.goods-image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background-color: #f3f3f3;
}

.goods-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-info.main {
  padding-top: 2rpx;
}

.goods-left {
  flex: 1;
  min-width: 0;
}

.goods-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-time {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.goods-price {
  font-size: 46rpx;
  color: #222;
  font-weight: 600;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 2rpx;
}

.order-meta {
  min-width: 80rpx;
}

.more-entry {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 10rpx 10rpx 4rpx;
}

.order-actions {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
  max-width: 72%;
}

.action-btn {
  margin: 0;
  border: 1rpx solid #e8d9ca;
  border-radius: 999rpx;
  padding: 0 26rpx;
  line-height: 58rpx;
  height: 58rpx;
  font-size: 30rpx;
  background-color: #fff;
  color: #8a8a8a;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background-color: #fff;
  color: #d8742f;
  border-color: #efc9a8;
}

.action-btn.ghost {
  color: #888;
  border-color: #ddd;
  background-color: #fff;
}

.order-summary {
  font-size: 22rpx;
  color: #888;
}

.more-arrow {
  font-size: 18rpx;
  color: #999;
}

.empty-order {
  padding: 200rpx 0 120rpx;
  text-align: center;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #4e5969;
}

.empty-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #86909c;
}