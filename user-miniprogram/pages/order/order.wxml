<view class="container">
  <view class="header">
    <text class="header-title">我的订单</text>
  </view>

  <view class="tab-section">
    <view class="tab-item active">全部</view>
    <view class="tab-item">待付款</view>
    <view class="tab-item">待收货</view>
    <view class="tab-item">已完成</view>
  </view>

  <view class="order-list">
    <view class="order-item">
      <view class="order-header">
        <text class="order-shop">塔斯汀</text>
        <text class="order-status">待收货</text>
      </view>
      <view class="order-content">
        <view class="order-goods">
          <image src="../../images/ai_example1.png" class="goods-image"></image>
          <view class="goods-info">
            <text class="goods-name">香辣鸡腿堡</text>
            <text class="goods-price">¥25</text>
          </view>
          <text class="goods-quantity">x1</text>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-total">合计：¥25</text>
        <view class="order-actions">
          <button class="action-btn">联系骑手</button>
          <button class="action-btn primary">确认收货</button>
        </view>
      </view>
    </view>

    <view class="order-item">
      <view class="order-header">
        <text class="order-shop">曼玲粥店</text>
        <text class="order-status">已完成</text>
      </view>
      <view class="order-content">
        <view class="order-goods">
          <image src="../../images/ai_example2.png" class="goods-image"></image>
          <view class="goods-info">
            <text class="goods-name">皮蛋瘦肉粥</text>
            <text class="goods-price">¥15</text>
          </view>
          <text class="goods-quantity">x1</text>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-total">合计：¥15</text>
        <view class="order-actions">
          <button class="action-btn">再次购买</button>
          <button class="action-btn">评价</button>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-order" wx:if="{{orders.length === 0}}">
    <text class="empty-text">暂无订单</text>
  </view>
</view>