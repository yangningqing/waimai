<view class="container">
  <view class="header">
    <text class="header-title">我的优惠券</text>
  </view>

  <view class="tab-section">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">未使用</view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">已使用</view>
    <view class="tab-item {{activeTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">已过期</view>
  </view>

  <view class="coupon-list" wx:if="{{currentCoupons.length > 0}}">
    <view class="coupon-item" wx:for="{{currentCoupons}}" wx:key="id">
      <view class="coupon-content">
        <view class="coupon-value">
          <text class="value-symbol">¥</text>
          <text class="value-number">{{item.value}}</text>
        </view>
        <view class="coupon-info">
          <text class="coupon-name">{{item.name}}</text>
          <text class="coupon-condition">满{{item.minSpend}}元可用</text>
          <text class="coupon-expiry">有效期至：{{item.expiryDate}}</text>
        </view>
        <view class="coupon-status" wx:if="{{activeTab === 1}}">已使用</view>
        <view class="coupon-status expired" wx:if="{{activeTab === 2}}">已过期</view>
      </view>
      <button class="use-btn" bindtap="useCoupon" wx:if="{{activeTab === 0}}">立即使用</button>
    </view>
  </view>

  <view class="empty-coupon" wx:else>
    <text class="empty-text">暂无优惠券</text>
  </view>
</view>