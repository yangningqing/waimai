<view class="container">
  <view class="top-tabs">
    <text class="tab active">{{tab}}</text>
  </view>

  <view class="card" bindtap="chooseAddress">
    <view class="card-title">收货地址</view>
    <text class="address-text" wx:if="{{selectedAddress}}">{{selectedAddressShort || selectedAddress.address}}</text>
    <text class="address-text muted" wx:else>请选择收货地址</text>
  </view>

  <view class="card">
    <view class="card-title">配送时间</view>
    <view class="row">
      <text class="chip {{deliveryMode==='immediate'?'active':''}}" data-mode="immediate" bindtap="switchDeliveryMode">立即送出</text>
      <text class="chip {{deliveryMode==='reserve'?'active':''}}" data-mode="reserve" bindtap="switchDeliveryMode">预约 {{reserveTime}}</text>
    </view>
  </view>

  <view class="card">
    <view class="shop-name">{{shopName}}</view>
    <view class="item-row" wx:for="{{items}}" wx:key="id">
      <text class="item-name">{{item.name}}</text>
      <text class="item-mid">x{{item.quantity}}</text>
      <text class="item-price">¥{{item.price}}</text>
    </view>
  </view>

  <view class="card">
    <view class="fee-row"><text>商品原价</text><text>¥{{goodsTotal}}</text></view>
    <view class="fee-row"><text>配送费</text><text>¥{{deliveryFee}}</text></view>
    <view class="fee-row"><text>红包/代金券</text><text>-¥{{couponDeduct}}</text></view>
  </view>

  <view class="card">
    <view class="fee-row"><text>订单备注</text></view>
    <input class="remark-input" placeholder="口味、偏好等要求（选填）" bindinput="onRemarkInput" value="{{remark}}" />
    <view class="fee-row"><text>餐具</text></view>
    <view class="row">
      <text class="chip {{tableware==='不需要餐具'?'active':''}}" data-value="不需要餐具" bindtap="chooseTableware">不需要餐具</text>
      <text class="chip {{tableware==='需要餐具'?'active':''}}" data-value="需要餐具" bindtap="chooseTableware">需要餐具</text>
    </view>
    <view class="fee-row"><text>支付方式</text></view>
    <view class="row">
      <text class="chip {{payment==='wxpay'?'active':''}}" data-value="wxpay" bindtap="choosePayment">微信支付</text>
      <text class="chip {{payment==='balance'?'active':''}}" data-value="balance" bindtap="choosePayment">余额支付</text>
    </view>
  </view>

  <view class="bottom-bar">
    <text class="total">合计：¥{{payable}}</text>
    <button class="pay-btn" bindtap="submitOrder">立即支付</button>
  </view>
</view>
