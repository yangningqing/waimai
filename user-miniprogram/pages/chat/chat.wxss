.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.message-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 20rpx;
  color: #999;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.system-message {
  display: flex;
  justify-content: center;
  margin: 20rpx 0;
}

.system-message text {
  background-color: rgba(0, 0, 0, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #666;
}

.message-item {
  display: flex;
  margin: 10rpx 0;
}

.message-item.sent {
  justify-content: flex-end;
}

.message-item.received {
  justify-content: flex-start;
}

.message-bubble {
  max-width: 70%;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  word-wrap: break-word;
  position: relative;
}

.message-bubble.sent {
  background-color: #07c160;
  color: white;
  border-bottom-right-radius: 4rpx;
}

.message-bubble.received {
  background-color: white;
  color: #333;
  border-bottom-left-radius: 4rpx;
}

.sender-label {
  font-size: 24rpx;
  opacity: 0.85;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.message-bubble.received .sender-label {
  color: #1a5c2e;
}

.message-bubble.sent .sender-label {
  color: rgba(255, 255, 255, 0.95);
}

.message-content {
  font-size: 32rpx;
  line-height: 1.4;
  display: block;
}

.message-time {
  font-size: 20rpx;
  opacity: 0.7;
  margin-top: 8rpx;
  text-align: right;
  display: block;
}

.input-container {
  display: flex;
  padding: 16rpx;
  background-color: white;
  border-top: 1rpx solid #e5e5e5;
  align-items: center;
  gap: 12rpx;
}

.input {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  background-color: #f5f5f5;
}

.send-button {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #07c160;
  color: white;
  border-radius: 40rpx;
  font-size: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.send-button::after {
  border: none;
}