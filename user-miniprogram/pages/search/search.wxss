.container {
  padding: 10px;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.search-header {
  display: flex;
  align-items: center;
  margin-bottom: 20px;
  padding: 10px 0;
  border-bottom: 1px solid #e0e0e0;
}

.search-input-container {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f0f0f0;
  border-radius: 20px;
  padding: 0 15px;
  margin-right: 10px;
}

.search-input {
  flex: 1;
  height: 40px;
  font-size: 14px;
}

.search-btn {
  color: #007aff;
  font-size: 14px;
  margin-left: 10px;
}

.cancel-btn {
  font-size: 14px;
  color: #666;
}

.search-history {
  margin-bottom: 20px;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.history-header text {
  font-size: 14px;
  color: #666;
}

.clear-history {
  color: #007aff;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.history-item {
  background-color: #fff;
  padding: 8px 15px;
  border-radius: 15px;
  font-size: 13px;
  color: #333;
  border: 1px solid #e0e0e0;
}

.hot-search {
  margin-bottom: 20px;
}

.hot-search-title {
  font-size: 14px;
  color: #666;
  margin-bottom: 10px;
  display: block;
}

.hot-search-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.hot-search-item {
  background-color: #fff;
  padding: 8px 15px;
  border-radius: 15px;
  font-size: 13px;
  color: #333;
  border: 1px solid #e0e0e0;
}

.search-results {
  margin-top: 20px;
}

.results-header {
  font-size: 14px;
  color: #666;
  margin-bottom: 10px;
}

.merchant-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.merchant-item {
  background-color: #fff;
  border-radius: 8px;
  padding: 15px;
  display: flex;
  gap: 15px;
}

.merchant-image {
  width: 80px;
  height: 80px;
  border-radius: 4px;
  object-fit: cover;
}

.merchant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.merchant-name {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.merchant-desc {
  font-size: 13px;
  color: #666;
}

.merchant-stats {
  display: flex;
  gap: 10px;
  font-size: 12px;
  color: #999;
}

.rating {
  color: #ff9500;
}
