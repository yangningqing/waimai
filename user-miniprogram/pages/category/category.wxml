<view class="container">
  <view class="category-container">
    <!-- 左侧分类列表 -->
    <view class="left-category">
      <view class="category-item {{activeCategory === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" data-id="{{item.id}}" bindtap="switchCategory">{{item.name}}</view>
    </view>

    <!-- 右侧商品列表 -->
    <view class="right-goods">
      <view class="category-title">{{currentCategoryName}}</view>
      <view class="goods-grid">
        <view class="goods-item" wx:for="{{currentGoods}}" wx:key="id" data-id="{{item.id}}" bindtap="navigateToGoodsDetail">
          <image src="{{item.image}}" class="goods-image"></image>
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>
  </view>
</view>