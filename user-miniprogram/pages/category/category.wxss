.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.category-container {
  display: flex;
  height: 100vh;
}

.left-category {
  width: 150rpx;
  background-color: #f0f0f0;
  overflow-y: auto;
}

.category-item {
  padding: 30rpx 20rpx;
  text-align: center;
  font-size: 32rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.category-item.active {
  background-color: #fff;
  color: #ff4757;
  font-weight: bold;
  position: relative;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 40rpx;
  background-color: #ff4757;
}

.right-goods {
  flex: 1;
  background-color: #fff;
  overflow-y: auto;
  padding: 20rpx;
}

.category-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.goods-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.goods-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
}

.goods-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.goods-name {
  font-size: 28rpx;
  margin-bottom: 10rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4757;
}