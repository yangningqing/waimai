<view class="container">
  <view class="header">
    <text class="header-title">我的优惠券</text>
  </view>

  <view class="tab-section">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">未使用</view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">已使用</view>
    <view class="tab-item {{activeTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">已过期</view>
  </view>

  <view class="coupon-list" wx:if="{{coupons.length > 0}}">
    <view class="coupon-item" wx:for="{{coupons}}" wx:key="id" data-id="{{item.id}}">
      <view class="coupon-left">
        <text class="coupon-amount">¥{{item.amount}}</text>
        <text class="coupon-condition">满{{item.condition}}元可用</text>
      </view>
      <view class="coupon-right">
        <text class="coupon-title">{{item.title}}</text>
        <text class="coupon-expiry">有效期至：{{item.expiry}}</text>
        <button class="coupon-btn" bindtap="useCoupon" data-id="{{item.id}}" wx:if="{{item.status === 'unused'}}">立即使用</button>
      </view>
    </view>
  </view>

  <view class="empty-coupon" wx:else>
    <text class="empty-text">暂无优惠券</text>
  </view>
</view>