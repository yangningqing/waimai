<view class="container">
  <!-- 顶部地址栏 -->
  <view class="header">
    <view class="location" bindtap="chooseLocation">
      <text>北京城市学院（顺义校区）</text>
      <text class="arrow">▼</text>
    </view>
    <view class="search-bar" bindtap="search">
      <input placeholder="搜索商家、商品" class="search-input"></input>
    </view>
  </view>



  <!-- 优惠券区域 -->
  <view class="coupon-section">
    <view class="coupon-item" wx:for="{{coupons}}" wx:key="index">
      <text class="coupon-amount">{{item.amount}}元</text>
      <text class="coupon-desc">{{item.description}}</text>
    </view>
    <button class="coupon-btn" bindtap="claimCoupons">一键领取</button>
  </view>

  <!-- 推荐商家 -->
  <view class="recommend-section">
    <view class="section-title">
      <text>附近商家</text>
      <text class="more" bindtap="search">查看更多</text>
    </view>
    <view class="merchant-list">
      <view class="merchant-item" wx:for="{{merchants}}" wx:key="id" bindtap="navigateToMerchant" data-id="{{item.id}}">
        <image src="{{item.image}}" class="merchant-image"></image>
        <view class="merchant-info">
          <text class="merchant-name">{{item.name}}</text>
          <text class="merchant-desc">{{item.description}}</text>
          <view class="merchant-stats">
            <text class="rating">{{item.rating}}</text>
            <text class="sales">月售{{item.sales}}</text>
            <text class="distance">{{item.distance}}</text>
            <text class="price">¥{{item.minPrice}}起送</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>