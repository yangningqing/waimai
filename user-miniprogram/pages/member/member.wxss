.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  display: block;
}

.user-status {
  font-size: 24rpx;
  color: #999;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
}

.member-card {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.member-info {
  margin-bottom: 20rpx;
}

.member-level {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.member-stars {
  font-size: 28rpx;
  color: #ff9800;
  margin-bottom: 10rpx;
  display: block;
}

.member-points {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.member-benefits {
  display: flex;
  gap: 20rpx;
}

.benefit-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.benefit-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.benefit-title {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 5rpx;
}

.benefit-desc {
  font-size: 20rpx;
  color: #999;
}

.function-section {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  display: flex;
  justify-content: space-around;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.function-icon {
  width: 50rpx;
  height: 50rpx;
}

.function-text {
  font-size: 24rpx;
  color: #333;
}

.order-section,
.wallet-section,
.coupon-section {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.order-items {
  display: flex;
  justify-content: space-around;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.order-icon {
  width: 50rpx;
  height: 50rpx;
}

.order-text {
  font-size: 24rpx;
  color: #333;
}

.wallet-items {
  display: flex;
  justify-content: space-around;
}

.wallet-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.wallet-icon {
  font-size: 24rpx;
  color: #333;
}

.wallet-amount {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4757;
}

.coupon-items {
  display: flex;
  gap: 15rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.coupon-item {
  background-color: #f9f9f9;
  border-radius: 10rpx;
  padding: 15rpx;
  min-width: 150rpx;
  text-align: center;
}

.coupon-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4757;
  margin-bottom: 5rpx;
  display: block;
}

.coupon-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.coupon-btn {
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 25rpx;
  padding: 15rpx;
  font-size: 32rpx;
  width: 100%;
}

.feedback-section {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.feedback-btn {
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 25rpx;
  padding: 15rpx;
  font-size: 32rpx;
  width: 100%;
}