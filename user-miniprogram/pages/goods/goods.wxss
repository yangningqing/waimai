.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.goods-info {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  display: flex;
  gap: 20rpx;
}

.goods-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
}

.goods-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.goods-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4757;
  margin-bottom: 10rpx;
}

.goods-sales {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.goods-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.shop-info {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.shop-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.shop-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.shop-rating {
  font-size: 28rpx;
  color: #ff9800;
  font-weight: bold;
  background-color: #fff3cd;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
}

.shop-stats {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.buy-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.quantity-btn {
  width: 50rpx;
  height: 50rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
}

.quantity {
  font-size: 28rpx;
  color: #333;
  min-width: 50rpx;
  text-align: center;
}

.add-to-cart-btn {
  flex: 1;
  background-color: #ff9800;
  color: #fff;
  border: none;
  border-radius: 25rpx;
  padding: 15rpx;
  font-size: 28rpx;
}

.buy-now-btn {
  flex: 1;
  background-color: #ff4757;
  color: #fff;
  border: none;
  border-radius: 25rpx;
  padding: 15rpx;
  font-size: 28rpx;
}