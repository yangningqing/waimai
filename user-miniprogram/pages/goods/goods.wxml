<view class="container">
  <!-- 店铺头部信息 -->
  <view class="shop-header">
    <image src="{{shop.image || '../../images/ai_example1.png'}}" class="shop-image"></image>
    <view class="shop-info">
      <text class="shop-name">{{shop.name}}</text>
      <text class="shop-rating">★{{shop.rating}}</text>
      <view class="shop-stats">
        <text class="stat-item">月售{{shop.sales}}</text>
        <text class="stat-item">{{shop.distance}}</text>
        <text class="stat-item">¥{{shop.minPrice}}起送</text>
      </view>
    </view>
  </view>

  <!-- 商品分类导航 -->
  <view class="category-nav">
    <view class="category-scroll">
      <view class="category-item {{activeCategory === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="switchCategory" data-id="{{item.id}}">{{item.name}}</view>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="goods-list">
    <view class="category-title">{{currentCategoryName}}</view>
    <view class="goods-grid">
      <view class="goods-item" wx:for="{{currentGoods}}" wx:key="id" data-id="{{item.id}}">
        <image src="{{item.image}}" class="goods-image"></image>
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">¥{{item.price}}</text>
          <text class="goods-sales">月售{{item.sales}}</text>
        </view>
        <view class="goods-actions">
          <view class="quantity-control" wx:if="{{item.quantity > 0}}">
            <button class="quantity-btn" bindtap="decreaseQuantity" data-id="{{item.id}}">-</button>
            <text class="quantity">{{item.quantity}}</text>
            <button class="quantity-btn" bindtap="increaseQuantity" data-id="{{item.id}}">+</button>
          </view>
          <button class="add-btn" bindtap="addToCart" data-id="{{item.id}}">{{item.quantity > 0 ? '已加' : '+'}}</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="checkout-bar">
    <view class="cart-info" bindtap="toggleCart">
      <image src="../../images/icons/cart.png" class="cart-icon"></image>
      <text class="cart-count">{{cartCount}}</text>
    </view>
    <view class="total-info">
      <text class="total-label">合计：</text>
      <text class="total-price">¥{{totalAmount}}</text>
    </view>
    <button class="checkout-btn" bindtap="checkout">去结算</button>
  </view>

  <!-- 购物车展开面板 -->
  <view class="cart-panel" wx:if="{{showCart}}">
    <view class="cart-panel-header">
      <text class="cart-panel-title">已选商品</text>
      <text class="cart-panel-close" bindtap="toggleCart">×</text>
    </view>
    <view class="cart-panel-content">
      <block wx:for="{{cartItems}}" wx:key="id" wx:for-index="shopIndex">
        <view class="cart-shop">
          <text class="cart-shop-name">{{item.shopName}}</text>
          <view class="cart-goods-list">
            <block wx:for="{{item.goods}}" wx:key="id" wx:for-index="goodsIndex">
              <view class="cart-goods-item">
                <image src="{{item.image}}" class="cart-goods-image"></image>
                <view class="cart-goods-info">
                  <text class="cart-goods-name">{{item.name}}</text>
                  <view class="cart-goods-price-quantity">
                    <text class="cart-goods-price">¥{{item.price}}</text>
                    <view class="cart-quantity-control">
                      <button class="cart-quantity-btn" bindtap="decreaseQuantity" data-id="{{item.id}}">-</button>
                      <text class="cart-quantity">{{item.quantity}}</text>
                      <button class="cart-quantity-btn" bindtap="increaseQuantity" data-id="{{item.id}}">+</button>
                    </view>
                  </view>
                </view>
              </view>
            </block>
          </view>
        </view>
      </block>
      <view wx:if="{{cartItems.length === 0}}" class="cart-empty">
        <text>购物车为空</text>
      </view>
    </view>
  </view>
</view>