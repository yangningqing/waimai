<view class="container">
  <view class="card">
    <text class="title">注册账号</text>
    <input
      class="input"
      placeholder="请输入账号"
      value="{{username}}"
      bindinput="onUsernameInput"
    />
    <input
      class="input"
      password
      placeholder="请输入密码"
      value="{{password}}"
      bindinput="onPasswordInput"
    />
    <button class="login-btn" bindtap="handleRegister">注册</button>
  </view>
</view>
