.container {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding: 60rpx 30rpx;
  box-sizing: border-box;
}

.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 36rpx 28rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 28rpx;
}

.input {
  height: 82rpx;
  border: 1rpx solid #e5e6eb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.login-btn {
  margin-top: 10rpx;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 12rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 30rpx;
}

.login-btn::after {
  border: none;
}
