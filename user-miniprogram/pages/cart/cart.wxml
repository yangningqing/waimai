<view class="cart-container">
  <view class="cart-header">
    <text class="cart-title">购物车</text>
  </view>
  <view class="address-bar" bindtap="chooseAddress">
    <text class="address-label">收货地址：</text>
    <text class="address-value">{{selectedAddressText || '请选择收货地址'}}</text>
    <text class="address-arrow">></text>
  </view>
  <view class="cart-content">
    <block wx:for="{{cartItems}}" wx:key="id" wx:for-index="shopIndex">
      <view class="shop-section">
        <view class="shop-header">
          <text class="shop-name">{{item.shopName}}</text>
        </view>
        <view class="goods-list">
          <block wx:for="{{item.goods}}" wx:key="id" wx:for-index="goodsIndex">
            <view class="goods-item">
              <image src="{{item.image}}" class="goods-image"></image>
              <view class="goods-info">
                <text class="goods-name">{{item.name}}</text>
                <view class="goods-price-quantity">
                  <text class="goods-price">¥{{item.price}}</text>
                  <view class="quantity-control">
                    <button class="quantity-btn" bindtap="decreaseQuantity" data-shop="{{shopIndex}}" data-goods="{{goodsIndex}}">-</button>
                    <text class="quantity">{{item.quantity}}</text>
                    <button class="quantity-btn" bindtap="increaseQuantity" data-shop="{{shopIndex}}" data-goods="{{goodsIndex}}">+</button>
                  </view>
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </block>
    <view wx:if="{{cartItems.length === 0}}" class="empty-cart">
      <text>购物车为空</text>
    </view>
  </view>
  <view class="cart-footer" wx:if="{{cartItems.length > 0}}">
    <view class="total-price">
      <text>合计：</text>
      <text class="price">¥{{totalAmount}}</text>
    </view>
    <button class="checkout-btn" bindtap="checkout">去结算</button>
  </view>
</view>