<view class="container">
  <view class="header">
    <text class="header-title">购物车</text>
  </view>

  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item" wx:for="{{cartItems}}" wx:key="id" data-shop="{{index}}">
      <view class="shop-info">
        <text class="shop-name">{{item.shopName}}</text>
        <text class="shop-desc">满{{item.minOrder}}元起送</text>
      </view>
      <view class="goods-info" wx:for="{{item.goods}}" wx:for-item="goods" wx:for-index="goodsIndex" wx:key="goods.id" data-goods="{{goodsIndex}}">
        <image src="{{goods.image}}" class="goods-image"></image>
        <view class="goods-details">
          <text class="goods-name">{{goods.name}}</text>
          <text class="goods-price">¥{{goods.price}}</text>
        </view>
        <view class="quantity-control">
          <button class="quantity-btn" bindtap="decreaseQuantity" data-shop="{{index}}" data-goods="{{goodsIndex}}">-</button>
          <text class="quantity">{{goods.quantity}}</text>
          <button class="quantity-btn" bindtap="increaseQuantity" data-shop="{{index}}" data-goods="{{goodsIndex}}">+</button>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-cart" wx:else>
    <text class="empty-text">购物车为空</text>
  </view>

  <view class="total-section" wx:if="{{cartItems.length > 0}}">
    <text class="total-label">合计：</text>
    <text class="total-value">¥{{totalAmount}}</text>
  </view>

  <view class="checkout-section" wx:if="{{cartItems.length > 0}}">
    <button class="checkout-btn" bindtap="checkout">去结算</button>
  </view>
</view>